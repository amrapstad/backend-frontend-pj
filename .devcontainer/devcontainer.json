{
  "name": "dev-container",
  "image": "mcr.microsoft.com/dotnet/sdk:9.0-noble",
  "forwardPorts": [5000, 5001],
  "portsAttributes": {
    "5001": { "label": "HTTPS" },
    "5000": { "label": "HTTP" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",                  
        "ms-dotnettools.csdevkit"
      ]
    }
  },
  "postCreateCommand": "dotnet new blazor -n app && cd app && dotnet restore"
}